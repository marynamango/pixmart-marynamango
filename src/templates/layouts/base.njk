<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Libre+Franklin:wght@400;@600&family=Plus+Jakarta+Sans:wght@500;@700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/normalize.css">
  <link rel="stylesheet" href="/css/style.css">
  <title>{{ title }}</title>
</head>
<body>
  <div class="layout-container">
    {% include "partials/header.njk" %}
    {% block content %}default content{% endblock %}
    {% include "partials/footer.njk" %}
  </div>
<script>
(function () {
  console.log("burgerMenu script loaded");
  burgerMenu();
})();

function burgerMenu() {
  const toggleBtn = document.querySelector(".header__menu");
  const nav = document.querySelector("nav#nav"); // or use ".nav" if you prefer

  console.log("toggleBtn:", toggleBtn);
  console.log("nav:", nav);
  const stopTransitionClass = "no-transition";
  let isResizing = false;

  if (!toggleBtn || !nav) return;

  // Toggle menu open/closed
  toggleBtn.addEventListener("click", () => {
    const isOpen = toggleBtn.classList.toggle("is-open");
    nav.hidden = !isOpen;
    toggleBtn.setAttribute("aria-expanded", isOpen);
  });

  // Debounce function to throttle resize/orientation events
  function debounce(func, wait) {
    let timeout;
    return function (...args) {
      clearTimeout(timeout);
      timeout = setTimeout(() => func.apply(this, args), wait);
    };
  }

  // On resize/orientation change, close the menu
  const handleResize = debounce(() => {
    if (!nav.hidden) {
      nav.hidden = true;
      toggleBtn.classList.remove("is-open");
      toggleBtn.setAttribute("aria-expanded", false);
    }
  }, 100);

  ["resize", "orientationchange"].forEach((event) => {
    window.addEventListener(event, handleResize);
  });

  // Prevent transition glitches during resizing
  const handleResizeEnd = debounce(() => {
    document.body.classList.remove(stopTransitionClass);
    isResizing = false;
  }, 100);

  window.addEventListener("resize", () => {
    if (!isResizing) {
      document.body.classList.add(stopTransitionClass);
      isResizing = true;
    } else {
      handleResizeEnd();
    }
  });
}
</script>
<script>
  document.addEventListener("DOMContentLoaded", () => {
    const toggleBtn = document.querySelector(".catalog-toolbar__filter-toggle");
    const closeBtn = document.querySelector(".catalog-filter__close");
    const filterDrawer = document.querySelector("#catalog_filter");

    if (!toggleBtn || !filterDrawer || !closeBtn) return;

    toggleBtn.addEventListener("click", () => {
      const isVisible = filterDrawer.classList.toggle("catalog-filter--visible");
      toggleBtn.setAttribute("aria-expanded", isVisible);
      document.body.style.overflow = isVisible ? "hidden" : "";
    });

    closeBtn.addEventListener("click", () => {
      filterDrawer.classList.remove("catalog-filter--visible");
      toggleBtn.setAttribute("aria-expanded", false);
      document.body.style.overflow = "";
    });
  });
</script>
</body>
</html>
