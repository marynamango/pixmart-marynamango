{% if folder %}
  {% set base = "/img/" + folder + "/" + basename %}
{% else %}
  {% set base = "/img/" + basename %}
{% endif %}
<picture>
  <source srcset="{{ base }}.avif 1x, {{ base }}-2x.avif 2x" type="image/avif">
  <source srcset="{{ base }}.webp 1x, {{ base }}-2x.webp 2x" type="image/webp">
  <img
    src="{{ base }}.webp"
    alt="{{ alt }}"
    class="{{ class }}"
    width="{{ width }}"
    height="{{ height }}"
    loading="lazy">
</picture>