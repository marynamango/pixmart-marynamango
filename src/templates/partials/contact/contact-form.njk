<form class="contact-form" action="{{ contact.form.action }}" method="post">
  {% for field in contact.form.fields %}
    {% set input = field %}
    {% if input.type == "textarea" %}
      <div class="contact-form__item">
        <label class="contact-form__label" for="{{ input.id }}">{{ input.label }}</label>
        <div class="contact-form__field-wrapper">
          <textarea
            class="contact-form__input contact-form__textarea"
            id="{{ input.id }}"
            name="{{ input.id }}"
            rows="{{ input.rows | default(5) }}"
            aria-describedby="{{ input.id }}_help {{ input.id }}_error {{ input.id }}_valid"
            {% if input.required %}required{% endif %}></textarea>
          {% if input.help %}
            <span class="contact-form__help" id="{{ input.id }}_help">{{ input.help }}</span>
          {% endif %}
          {% if input.error %}
            <span class="contact-form__error" id="{{ input.id }}_error">{{ input.error }}</span>
          {% endif %}
          {% if input.validated %}
            <span class="contact-form__valid" id="{{ input.id }}_valid">{{ input.validated }}</span>
          {% endif %}
        </div>
      </div>
    {% elseif input.type == "select" %}
      <div class="contact-form__item">
        <label for="{{ input.id }}" class="contact-form__label">{{ input.label }}</label>
        <div class="contact-form__field-wrapper">
          <div class="contact-form__select-wrapper">
            <select
              id="{{ input.id }}"
              name="{{ input.id }}"
              class="contact-form__select"
              aria-describedby="{{ input.id }}_help {{ input.id }}_error {{ input.id }}_valid"
              {% if input.required %}required{% endif %}>
              <option value="" selected disabled hidden>{{ input.option }}</option>
              {% for option in input.options %}
                <option 
                  value="{{ option | lower | replace(' ', '-') }}"
                >
                  {{ option }}
                </option>
              {% endfor %}
            </select>
            {% if input.help %}
              <span class="contact-form__help" id="{{ input.id }}_help">{{ input.help }}</span>
            {% endif %}
            {% if input.error %}
              <span class="contact-form__error" id="{{ input.id }}_error">{{ input.error }}</span>
            {% endif %}
            {% if input.validated %}
              <span class="contact-form__valid" id="{{ input.id }}_valid">{{ input.validated }}</span>
            {% endif %}
            <svg class="icon contact-form__arrow" aria-hidden="true" focusable="false">
              <use href="/img/sprite.svg#chevron-left"></use>
            </svg>
          </div>
        </div>
      </div>
    {% else %}
      <div class="contact-form__item">
        <label class="contact-form__label" for="{{ input.id }}">{{ input.label }}</label>
        <div class="contact-form__field-wrapper">
          <input
            class="contact-form__input"
            id="{{ input.id }}"
            type="{{ input.type }}"
            name="{{ input.id }}"
            placeholder="{{ input.placeholder }}"
            aria-describedby="{{ input.id }}_help {{ input.id }}_error {{ input.id }}_valid"
            {% if input.required %}required{% endif %}
            {% if input.minlength %}minlength="{{ input.minlength }}"{% endif %}
            {% if input.min %}min="{{ input.min }}"{% endif %}
            {% if input.max %}max="{{ input.max }}"{% endif %}
            {% if input.pattern %}pattern="{{ input.pattern | safe }}"{% endif %}
          />
          {% if input.help %}
            <span class="contact-form__help" id="{{ input.id }}_help">{{ input.help }}</span>
          {% endif %}
          {% if input.error %}
            <span class="contact-form__error" id="{{ input.id }}_error">{{ input.error }}</span>
          {% endif %}
          {% if input.validated %}
            <span class="contact-form__valid" id="{{ input.id }}_valid">{{ input.validated }}</span>
          {% endif %}
        </div>
      </div>
    {% endif %}
  {% endfor %}

  <div class="contact-form__footer">
    <div class="contact-form__checkbox-wrapper">
      {% for checkbox in contact.form.checkboxes %}
        <input
          class="visually-hidden checkbox-input"
          type="checkbox"
          name="{{ checkbox.id }}"
          value="agree"
          id="{{ checkbox.id }}"
          {% if checkbox.required %}required{% endif %} />
        <label class="checkbox-label contact-form__label" for="{{ checkbox.id }}">
          <svg class="checkbox-label__icon" aria-hidden="true" focusable="false">
            <use href="/img/sprite.svg#checkmark"></use>
          </svg>{{ checkbox.label }}</label>
      {% endfor %}
    </div>

    {% set button = contact.form.button %}
    {% include "partials/components/button.njk" %}
  </div>
</form>