<div class="contact-info">
  <div class="contact-info__header">
    <span class="contact-info__label">Contact</span>
    <h1 class="contact-info__title">Get in Touch with Us</h1>
    <p class="contact-info__desc">We are here to help you navigate your creative journey. Reach out for any questions, support, or feedback.</p>
  </div>
  <a href="products.html" class="button button--primary">Shop Now</a>

  <ul class="contact-info__list">
    <li class="contact-info__item">
      <svg class="icon icon--accent" aria-hidden="true" focusable="false">
        <use href="/img/sprite.svg#phone.svg"></use>
      </svg>
      <a class="contact-info__info" href="tel:+15551234567">+1 (555) 123-4567</a>
    </li>
    <li class="contact-info__item">
      <svg class="icon icon--accent" aria-hidden="true" focusable="false">
        <use href="/img/sprite.svg#mail.svg"></use>
      </svg>
      <a class="contact-info__info" href="mailto:support@pixmart.com">support@pixmart.com</a>
    </li>
    <li class="contact-info__item">
      <svg class="icon icon--accent" aria-hidden="true" focusable="false">
        <use href="/img/sprite.svg#time.svg"></use>
      </svg>
      <span class="contact-info__info">Monday to Friday: 9 AM - 5 PM EST</span>
    </li>
  </ul>
  <div class="contact-map">
    <picture class="contact-map__image-wrapper">
      <source srcset="/img/map.webp" type="image/webp"/>
      <img
        class="contact-map__image"
        src="/img/map.png"
        alt="Map showing location of PixMart HQ at 123 Creative Ave, Design City" 
        loading="lazy"
      />
    </picture>

    <div class="contact-map__marker">
      <svg class="icon icon--accent" aria-hidden="true" focusable="false">
        <use href="/img/sprite.svg#marker-pin.svg"></use>
      </svg>
      <div class="contact-map__text">
        <h2 class="contact-map__title">PixMart HQ</h2>
        <p class="contact-map__address">123 Creative Ave, Design City, 45678</p>
      </div>
    </div>
  </div>
</div>