<header class="header">
      <div class="header__wrapper">
        <div class="header__burger-group">
          <button
            type="button"
            class="header__menu"
            aria-label="Toggle menu"
            aria-expanded="false"
            aria-controls="nav">
            <span class="header__menu-icon"></span>
          </button>
          
          {% include "partials/components/logo.njk" %}
        </div>

        {% include "partials/components/nav.njk" %}

        <div class="header__actions">
          <form class="search" action="/search" method="get">
            <input
              class="search__input"
              type="search"
              name="q"
              placeholder="Search for Digital Assets"
              minlength="3"
              required />
            <button class="search__button" type="submit">
              <img
                class="search__icon"
                src="/img/search.svg"
                alt="Search icon"
                width="24"
                height="24" />
            </button>
          </form>

          <a href="#" class="button button--primary button--only-icon">
            <img src="#" alt="Shop icon" width="24" height="24" />
          </a>
        </div>
      </div>
    </header>