<header class="header">
      <div class="header__wrapper">
        <div class="header__burger-group">
          <button
            type="button"
            class="header__menu"
            aria-label="Toggle menu"
            aria-expanded="false"
            aria-controls="nav">
            <span class="header__menu-icon"></span>
          </button>
          
          {% include "partials/components/logo.njk" %}
        </div>

        <nav class="nav" id="nav" hidden>
          <ul class="nav__list">
            <li class="nav__item">
              <a href="index.html" class="nav__link">About</a>
            </li>

            <li class="nav__item">
              <a href="products.html" class="nav__link">Products</a>
            </li>

            <li class="nav__item">
              <a href="creators.html" class="nav__link">Creators</a>
            </li>

            <li class="nav__item">
              <a href="blog.html" class="nav__link">Blog</a>
            </li>

            <li class="nav__item">
              <a href="contact.html" class="nav__link">Contact</a>
            </li>
          </ul>
        </nav>

        <div class="header__actions">
          <form class="search" action="/search" method="get">
            <input
              class="search__input"
              type="search"
              name="q"
              placeholder="Search for Digital Assets"
              minlength="3"
              required />
            <button class="search__button" type="submit">
              <img
                class="search__icon"
                src="/img/search.svg"
                alt="Search icon"
                width="24"
                height="24" />
            </button>
          </form>

          <a href="#" class="button button--primary button--only-icon">
            <img src="#" alt="Shop icon" width="24" height="24" />
          </a>
        </div>
      </div>
    </header>