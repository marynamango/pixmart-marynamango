<aside class="aside">
          <div class="aside__author">
            {% set picture = aside.author.picture %}
            {% include "partials/components/picture.njk" %}
            <div class="aside__author-info">
              <p class="aside__author-name">{{ aside.author.name }}</p>
              <time class="aside__author-date" datetime="{{ aside.author.date.datetime }}">
                {{ aside.author.date.display }}
              </time>
            </div>
          </div>

          <div class="aside__categories">
            <h2 class="aside__categories-title">{{ aside.categoriesHeading }}</h2>
            <ul class="aside__categories-list">
              {% for category in aside.categories %}
              <li class="aside__categories-item">
                <a href="{{ category.href }}" class="aside__categories-link">{{ category.name }}</a>
              </li>
              {% endfor %}
            </ul>
          </div>

          <div class="aside__articles">
            <h2 class="aside__articles-title">{{ aside.latestArticlesHeading }}</h2>
            <ul class="aside__articles-list">
              {% for article in aside.latestArticles %}
              <li class="aside__articles-item">
                <a class="aside__article-link" href="{{ article.href }}">{{ article.title }}</a>
                <time class="aside__article-date" datetime="{{ article.date.datetime }}">
                  {{ article.date.display }}
                </time>
              </li>
              {% endfor %}
            </ul>
          </div>
        </aside>