{% extends "layouts/base.njk" %}

{% block content %}
  <main class="main-container">
    {% include "partials/index/promo.njk" %}

    {% include "partials/index/assets.njk" %}

    {% include "partials/index/categories.njk" %}

    <section class="products">
      <div class="products__header">
        <div class="section-header">
          <span class="section-header__label">Trending</span>
          <h2 class="section-header__title">Popular Products</h2>
        </div>
        <div class="products__controls">
          <button type="button" class="button button--secondary button--icon">
            <img src="#" alt="Chevron left" width="24" height="24"/>
          </button>
          <button type="button" class="button button--secondary button--icon">
            <img src="#" alt="Chevron right" width="24" height="24"/>
          </button>
        </div>
      </div>

      <div class="products__slider">
        <article class="product-card">
          <a class="product-card__link" href="#">
            <div class="badge badge--icon badge--ribbon">
              <img src="icons/trophy.svg" alt="Trophy" width="24" height="24"/>
            </div>
            <img class="product-card__img" src="img/travel-hero.webp" alt="Travel page template" width="305" height="272" loading="lazy"/>
          </a>
          <div class="product-card__info">
            <h3 class="product-card__title">Travel Hero</h3>
            <span class="product-card__price">€29.99</span>
          </div>
          <div class="product-card__tags">
            <span class="product-card__tag">Adventure</span>
            <span class="product-card__tag">Journey</span>
          </div>
        </article>

        <article class="product-card">
          <a class="product-card__link" href="#">
            <div class="badge badge--icon badge--ribbon">
              <img src="icons/trophy.svg" alt="Trophy" width="24" height="24"/>
            </div>
            <img class="product-card__img" src="img/healthcare-pro.webp" alt="Healthcare page template" width="305" height="272" loading="lazy"/>
          </a>
          <div class="product-card__info">
            <h3 class="product-card__title">Healthcare Pro</h3>
            <span class="product-card__price">€15.99</span>
          </div>
          <div class="product-card__tags">
            <span class="product-card__tag">Medical</span>
            <span class="product-card__tag">Wellness</span>
          </div>
        </article>

        <article class="product-card">
          <a class="product-card__link" href="#">
            <img class="product-card__img" src="img/foodish-delight.webp" alt="Foodish page template" width="305" height="272" loading="lazy"/>
          </a>
          <div class="product-card__info">
            <h3 class="product-card__title">Foodish Delight</h3>
            <span class="product-card__price">€31.99</span>
          </div>
          <div class="product-card__tags">
            <span class="product-card__tag">Catering</span>
            <span class="product-card__tag">Food</span>
          </div>
        </article>

        <article class="product-card">
          <a class="product-card__link" href="#">
            <img class="product-card__img" src="img/real-estate.webp" alt="Real Estate page template" width="305" height="272" loading="lazy"/>
          </a>
          <div class="product-card__info">
            <h3 class="product-card__title">Travel Hero</h3>
            <span class="product-card__price">€40.99</span>
          </div>
          <div class="product-card__tags">
            <span class="product-card__tag">Modern</span>
            <span class="product-card__tag">Homes</span>
          </div>
        </article>

      </div>
    </section>

    <section class="pricing">
      <div class="section-header">
        <span class="section-header__label">Pricing plan</span>
        <h2 class="section-header__title">Choose The Perfect Plan for Creative Potential</h2>
      </div>
      <div class="pricing__plans">
        <article class="pricing-card">
          <h3 class="pricing-card__title">Standard Membership</h3>
          <p class="pricing-card__price">€14.99 <span class="pricing-card__period">/ Month</span></p>
          <ul class="pricing-card__features">
            <li class="pricing-card__benefit">Enhanced Resource Access</li>
            <li class="pricing-card__benefit">Monthly Credits</li>
            <li class="pricing-card__benefit">Priority Customer Support</li>
            <li class="pricing-card__benefit">Community Features Access</li>
          </ul>
          <button class="button button--secondary">Subscribe</button>
        </article>

        <article class="pricing-card pricing-card--highlighted">
          <div class="badge badge--bestseller badge--ribbon">Best Seller</div>
          <h3 class="pricing-card__title">Plus Membership</h3>
          <p class="pricing-card__price">€29.99 <span class="pricing-card__period">/ Month</span></p>
          <ul class="pricing-card__features">
            <li class="pricing-card__benefit">All Standard Benefits</li>
            <li class="pricing-card__benefit">Increased Monthly Credits</li>
            <li class="pricing-card__benefit">Early Access to New Releases</li>
            <li class="pricing-card__benefit">Member-Only Offers</li>
          </ul>
          <button class="button button--primary">Subscribe</button>
        </article>

        <article class="pricing-card">
          <h3 class="pricing-card__title">Pro Membership</h3>
          <p class="pricing-card__price">€49.99 <span class="pricing-card__period">/ Month</span></p>
          <ul class="pricing-card__features">
            <li class="pricing-card__benefit">All Plus Benefits</li>
            <li class="pricing-card__benefit">Unlimited Downloads</li>
            <li class="pricing-card__benefit">Custom Licensing</li>
            <li class="pricing-card__benefit">Direct Creator Collaboration</li>
          </ul>
          <button class="button button--secondary">Subscribe</button>
        </article>

      </div>
    </section>

    <section class="faq">
      <div class="section-header">
        <span class="section-header__label">F.A.Q</span>
        <h2 class="section-header__title">Answers to Your Questions</h2>
        <button class="button button--secondary">Ask Us A Question</button>
      </div>
      <div class="faq__container">
        <details class="faq__details">
          <summary class="faq__summary">Can I request a refund?</summary>
          <div class="faq__content">
            <p class="faq__answer">Accessing your purchased products is seamless and hassle-free on our digital design assets marketplace. Simply log in to your account, navigate to the 'My Purchases' section, and you'll find all your purchased products ready for download.</p>
          </div>
        </details>
        <details class="faq__details" open>
          <summary class="faq__summary">How do I access my purchased products?</summary>
          <div class="faq__content">
            <p class="faq__answer">Accessing your purchased products is seamless and hassle-free on our digital design assets marketplace. Simply log in to your account, navigate to the 'My Purchases' section, and you'll find all your purchased products ready for download.</p>
          </div>
        </details>
        <details class="faq__details">
          <summary class="faq__summary">Are there any discounts for bulk purchases?</summary>
          <div class="faq__content">
            <p class="faq__answer">Accessing your purchased products is seamless and hassle-free on our digital design assets marketplace. Simply log in to your account, navigate to the 'My Purchases' section, and you'll find all your purchased products ready for download.</p>
          </div>
        </details>
        <details class="faq__details">
          <summary class="faq__summary">What payment methods do you accept here?</summary>
          <div class="faq__content">
            <p class="faq__answer">Accessing your purchased products is seamless and hassle-free on our digital design assets marketplace. Simply log in to your account, navigate to the 'My Purchases' section, and you'll find all your purchased products ready for download.</p>
          </div>
        </details>
        <details class="faq__details">
          <summary class="faq__summary">Can I sell my digital products on this marketplace?</summary>
          <div class="faq__content">
            <p class="faq__answer">Accessing your purchased products is seamless and hassle-free on our digital design assets marketplace. Simply log in to your account, navigate to the 'My Purchases' section, and you'll find all your purchased products ready for download.</p>
          </div>
        </details>
      </div>
    </section>

    <section class="articles">
      <div class="section-header">
        <h2 class="section-header__title">Latest Expert</h2>
        <a href="#">Explore All Articles
            <svg class="icon icon-small">
            <use href="/img/sprite.svg#chevron-right"></use>
          </svg>
        </a>
      </div>
      <div class="articles__list">
        <article class="articles__item">
          <img
                class="articles__img"
                src="img/blog-1x.webp"
                alt="Creative blog"
                width="624"
                height="702"
          />
          <h3 class="articles__subtitle">Creative Blog</h3>
          <time class="articles__date" datetime="2024-04-15">
              15 APRIL 2024
            </time>
        </article>
        <article class="articles__item">
          <img
                class="articles__img"
                src="img/best-dishes-1x.webp"
                alt="Creative blog"
                width="624"
                height="702"
          />
          <h3 class="articles__subtitle">Best Dishes</h3>
          <time class="articles__date" datetime="2024-05-05">
              5 MAY 2024
            </time>
        </article>
      </div>
    </section>
  </main>
{% endblock %}