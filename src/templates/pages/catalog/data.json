{
  "title": "Products",
  "catalogHero": {
    "title": "Explore Top",
    "highlight": "UI Kits",
    "suffix": "Design Assets"
  },
  "filterCloseButton": {
    "modFirst": "only-icon",
    "modSecond": "secondary",
    "extraClass": "catalog-filter__close",
    "ariaLabel": "Close filters",
    "typeAttr": "button",
    "icon": {
      "name": "x-close",
      "class": "icon--black"
    }
  },
  "filterClearButton": {
    "text": "Clear all filters",
    "modFirst": "secondary",
    "modSecond": "full",
    "icon": {
      "name": "x-close",
      "class": "icon--black"
    },
    "extraClass": "catalog-filter__clear",
    "ariaLabel": "Clear all filters",
    "typeAttr": "button"
  },
  "filters": [
    {
      "title": "Categories",
      "name": "category",
      "type": "checkbox",
      "options": ["All Categories", "Technology", "Travel & Tourism", "Health & Fitness", "E-Commerce", "Education", "Entertainment", "Others", "Other"]
    },
    {
      "title": "Format Type",
      "name": "format",
      "type": "radio",
      "options": ["Figma", "Sketch", "Adobe XD", "Adobe Photoshop", "Adobe Illustration"]
    },
    {
      "title": "Style",
      "name": "style",
      "type": "toggle",
      "options": ["Minimalist", "Modern", "Playful", "Dark Mode", "Photocentric"]
    }
  ],
  "filterForm": {
    "title": "Filters",
    "button": {
      "text": "Save",
      "modFirst": "primary",
      "modSecond": "full",
      "extraClass": "catalog-filter__save",
      "ariaLabel": "Save filter settings"
    }
  },
  "price": {
    "title": "Price",
    "min": "€5",
    "max": "€50"
  },
  "catalogToolbar": {
    "select": {
      "id": "sort",
      "options": [
        { "value": "bestseller", "label": "Best Seller" },
        { "value": "new", "label": "New" },
        { "value": "soldout", "label": "Sold Out" },
        { "value": "popular", "label": "Popular" }
      ]
    },
    "resultCount": "Showing 12 out of 120 results",
    "filterToggleButton": {
      "modFirst": "only-icon",
      "modSecond": "primary",
      "extraClass": "catalog-toolbar__filter-toggle mobile-only",
      "ariaLabel": "Open filters",
      "icon": {
        "name": "filter"
      }
    },
    "layoutButtons": {
      "grid": {
        "modFirst": "only-icon",
        "modSecond": "primary",
        "ariaLabel": "Grid view",
        "icon": {
          "name": "grid",
          "class": "icon--white"
        }
      },
      "list": {
        "modFirst": "only-icon",
        "modSecond": "secondary",
        "ariaLabel": "List view",
        "icon": {
          "name": "list"
        }
      }
    },
    "tags": [
      {
        "text": "UI Kit",
        "button": {
          "extraClass": "catalog-toolbar__tag-button",
          "typeAttr": "button",
          "ariaLabel": "Remove UI Kit",
